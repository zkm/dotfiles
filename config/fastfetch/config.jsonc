{
    "logo": {
        "source": "fedora",
        "color": {
            "1": "#51A2DA",
            "2": "white"
        }
    },
    "display": {
        "separator": " п…ё ",
        "constants": [
            "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" // {$1}, used in Custom module
        ],
        "color": {
            "keys": "#51A2DA"
        },
        "key": {
            "type": "icon",
            "paddingLeft": 2
        }
    },
    "modules": [
        {
            "type": "custom", // HardwareStart
            // {#1} is equivalent to `\u001b[1m`. {#} is equivalent to `\u001b[m`
            "format": "в”Ң{$1}{#1}Hardware Information{#}{$1}в”җ"
        },
        { "type": "host"},
        { "type": "cpu"},
        { "type": "gpu"},
        {
            "type": "command",
            "key": "Disk",
            "keyIcon": "у°ӢҠ",
            "text": "df -B1 -x tmpfs -x devtmpfs -x squashfs -x overlay --output=size,used | awk 'NR>1 {s+=$1; u+=$2} END {if(s>0) printf \"%.2f TiB / %.2f TiB (%.0f%%)\", u/1099511627776, s/1099511627776, (u/s)*100; else print \"n/a\"}'"
        },
        { "type": "memory"},
        { "type": "display", "keyIcon": "у°Қ№" },
        {
            "type": "command",
            "key": "Battery",
            "keyIcon": "пүҖ",
            "text": "bat=$(ls -d /sys/class/power_supply/BAT* 2>/dev/null | head -n1); if [ -n \"$bat\" ] && [ -r \"$bat/capacity\" ]; then cap=$(cat \"$bat/capacity\" 2>/dev/null); status=$(cat \"$bat/status\" 2>/dev/null); if [ -n \"$cap\" ]; then if [ -n \"$status\" ]; then printf '%s%% [%s]' \"$cap\" \"$status\"; else printf '%s%%' \"$cap\"; fi; fi; fi"
        },
        { "type": "bluetooth", "keyIcon": "пҠ“" },
        { "type": "sound", "keyIcon": "пҖЁ" },
        {
            "type": "custom", // SoftwareStart
            "format": "в”ң{$1}{#1}Software Information{#}{$1}в”Ө"
        },
        {
            "type": "title",
            "keyIcon": "пҖҮ",
            "key": "Title", // Title module has no key by default, so that icon is not displayed
            "format": "{user-name}@{host-name}"
        },
        { "type": "os"},
        { "type": "kernel"},
        { "type": "lm"},
        { "type": "de", "keyIcon": "п„Ҳ" },
        { "type": "wm", "keyIcon": "пӢ’" },
        { "type": "shell", "keyIcon": "п„ " },
        { "type": "terminal", "keyIcon": "п’ү" },
        { "type": "theme", "keyIcon": "пҮј" },
        { "type": "icons", "keyIcon": "пҖҫ" },
        { "type": "packages"},
        {
            "type": "custom", // SystemStatusStart
            "format": "в”ң{$1}{#1}System & Network{#}{$1}в”Ө"
        },
        {
            "type": "localip",
            "compact": true
        },
        {
            "type": "publicip",
            "timeout": 1000
        },
        {
            "type": "command",
            "key": "Wi-Fi",
            "keyIcon": "пҮ«",
            "text": "ssid=$(nmcli -t -f active,ssid dev wifi 2>/dev/null | awk -F: '$1==\"yes\"{print $2; exit}'); if [ -n \"$ssid\" ]; then printf '%s' \"$ssid\"; else iwgetid -r 2>/dev/null; fi"
        },
        { "type": "uptime", "keyIcon": "пү’" },
        {
            "type": "command",
            "key": "OS Age",
            "keyIcon": "пҮҪ",
            "text": "birth_date=$(stat / --format='%w' 2>/dev/null | cut -d' ' -f1-2); if [ -n \"$birth_date\" ]; then birth_timestamp=$(date -d \"$birth_date\" +%s 2>/dev/null); if [ -n \"$birth_timestamp\" ]; then now=$(date +%s); age_seconds=$((now - birth_timestamp)); age_days=$((age_seconds / 86400)); if [ $age_days -lt 1 ]; then echo 'Less than 1 day'; elif [ $age_days -lt 365 ]; then echo \"$age_days days\"; else years=$((age_days / 365)); months=$(((age_days % 365) / 30)); if [ $months -eq 0 ]; then echo \"$years years\"; else echo \"$years years, $months months\"; fi; fi; fi; fi"
        },
        {
            "type": "command",
            "key": "Datetime",
            "keyIcon": "пҖ—",
            "text": "date '+%Y-%m-%d %H:%M:%S'"
        },
        {
            "type": "custom", // InformationEnd
            "format": "в””{$1}{$1}{$1}в”ҳ"
        },
        {
            "type": "colors",
            "paddingLeft": 2,
            "symbol": "circle"
        }
    ]
}
