# Smart system info display (fastfetch > neofetch)
neofetch() {
  if command -v fastfetch >/dev/null 2>&1; then
    fastfetch "$@"
  elif command -v neofetch >/dev/null 2>&1; then
    command neofetch "$@"
  else
    echo "❌ Neither fastfetch nor neofetch is installed." >&2
    return 1
  fi
}

