# Smart vim/nvim fallback
vim() {
  if command -v nvim >/dev/null 2>&1; then
    command nvim "$@"
  elif command -v vim >/dev/null 2>&1; then
    command vim "$@"
  else
    echo "❌ No 'nvim' or 'vim' installed." >&2
    return 1
  fi
}

vi() {
  vim "$@"
}

